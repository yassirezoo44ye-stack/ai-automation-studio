# ── Required ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Render provides this automatically via the DATABASE_URL binding in render.yaml.
# Local dev: use docker-compose (see docker-compose.yml).
DATABASE_URL=postgresql://user:password@host:5432/dbname

# HMAC signing key for subscription tokens.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# WARNING: changing this invalidates all existing tokens (all users are logged out).
SESSION_SECRET=change-me-generate-a-random-64-char-hex-string

# ── AI ────────────────────────────────────────────────────────────────────────
# Anthropic API key — required for all AI features (Chat, Build, Social, Design, Tasks).
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Stripe ────────────────────────────────────────────────────────────────────
# Secret key (sk_live_... for production, sk_test_... for development).
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret — get from the Stripe dashboard → Webhooks.
STRIPE_WEBHOOK_SECRET=whsec_...

# Price ID for the $1/month subscription plan (legacy flat trial gate).
STRIPE_PRICE_ID=price_...

# Org-scoped tiered plan prices — create these as recurring Stripe Prices,
# one per paid tier. Enterprise has no Stripe price (contact-sales).
STRIPE_PRICE_ID_STARTER=price_...
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_TEAM=price_...

# ── Deployment ────────────────────────────────────────────────────────────────
# Full public URL of the deployed app — used in Stripe redirect URLs.
# Example: https://axon.onrender.com
APP_URL=http://localhost:8000

# Port to listen on (defaults to 8000 if not set).
PORT=8000

# ── Optional overrides ────────────────────────────────────────────────────────
# Directory where build workspaces are stored (defaults to ./workspaces).
# WORKSPACES_DIR=./workspaces

# ── AI Providers (optional extras) ───────────────────────────────────────────
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...

# OpenRouter — one key, many models. Optional default model override
# (defaults to openrouter/auto).
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_DEFAULT_MODEL=openrouter/auto

# Local/self-hosted OpenAI-compatible server (Ollama, LM Studio, vLLM, ...).
# Provider is available whenever LOCAL_MODEL_BASE_URL is set, API key optional.
# LOCAL_MODEL_BASE_URL=http://localhost:11434/v1
# LOCAL_MODEL_DEFAULT=llama3
# LOCAL_MODEL_API_KEY=local

# ── OAuth ─────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── Redis (optional — falls back to in-process cache) ────────────────────────
# Redis URL for distributed caching, rate-limiting, job queue, and pub/sub.
# Set this in production for multi-instance deployments.
# REDIS_URL=redis://localhost:6379/0

# ── Email (optional — logs to console when unset) ────────────────────────────
# Used for verification, password-reset, and alert-webhook emails.
# Unset SMTP_HOST means outgoing email is logged instead of sent (dev default).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@axon.app

# ── Database tuning (optional — sane defaults for a small instance) ─────────
# DB_POOL_MIN=2
# DB_POOL_MAX=10
# DB_COMMAND_TIMEOUT_S=60
# DB_ACQUIRE_TIMEOUT_S=10

# ── Background jobs (optional) ────────────────────────────────────────────────
# Worker-pool size for the scheduler's job dispatch semaphore.
# JOB_WORKERS=10

# ── Sandbox / plugin execution (optional) ────────────────────────────────────
# Force the sandbox backend instead of auto-probing Docker. Set to "process"
# in CI/dev environments without Docker, or "docker" to require it.
# SANDBOX_BACKEND=process

# Enables the Docker-backed code-execution runtime. Off by default.
# DOCKER_ENABLED=false

# Allow POST /api/plugins/{id}/reload to hot-reload a plugin without a
# full unload/reinstall. Dev only — never enable in production.
# PLUGIN_HOT_RELOAD_ENABLED=false

# ── JWT ───────────────────────────────────────────────────────────────────────
# NOT currently read by the app — app/core/jwt_utils.py signs JWTs with
# SESSION_SECRET (see above), not a separate secret. Reserved for a future
# split; setting this does nothing today. Left unset intentionally.
# JWT_SECRET=change-me

# ── Environment ───────────────────────────────────────────────────────────────
# "production" (default) or "development". Controls dev-only conveniences
# like the feature-gate bypass below. Defaults to "production" — an unset
# or misspelled value is always treated as production, never development.
# ENVIRONMENT=development

# ── Dev helpers ───────────────────────────────────────────────────────────────
# Pre-register an API key with admin scope for development. Shown once at startup.
# AXON_DEV_API_KEY=axon_dev_replace_me

# Bypass plan/subscription feature gating (app/billing/feature_gate.py) so a
# local dev can exercise paid-tier features (e.g. Marketplace) without a real
# Stripe subscription. Requires ENVIRONMENT=development to have ANY effect —
# setting this alone does nothing, and it is always ignored in production
# regardless of this value. Never enable in a deployed/production environment.
# FEATURE_GATE_DEV_BYPASS=true

# Seed a fixed-UUID demo user at startup. Local dev / CI only — never set
# in production (the demo UUID is a known value, a data-isolation risk in
# a multi-user environment).
# SEED_DEMO_USER=false

# ── Observability (optional — safe defaults for production) ─────────────────
# Log verbosity: DEBUG | INFO | WARNING | ERROR. Defaults to INFO.
# LOG_LEVEL=INFO

# OTel trace sampling rate, 0.0-1.0. Defaults to 1.0 (sample everything) —
# consider lowering for high-traffic production deployments to reduce
# tracing overhead and storage cost.
# OBS_SAMPLING_RATE=1.0

# Export traces to a real OTLP collector (e.g. Jaeger, Honeycomb) in
# addition to the in-memory ring buffer /api/diagnostics reads from.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# How long a cached /health/deep snapshot is served before re-probing.
# HEALTH_SNAPSHOT_TTL_S=5
