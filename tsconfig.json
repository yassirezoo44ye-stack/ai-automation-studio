{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@shared/*":   ["src/renderer/shared/*"],
      "@features/*": ["src/renderer/features/*"],
      "@core/*":     ["src/renderer/core/*"],
      "@app/*":      ["src/renderer/app/*"]
    }
  },
  "include": ["src"]
}